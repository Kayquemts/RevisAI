# Copie este arquivo para .env e preencha com suas credenciais
# cp .env.example .env

# Região da AWS onde a função Lambda está deployada
AWS_REGION=us-east-2

# Credenciais da AWS com permissão de invocar a função Lambda "flashcard-api"
AWS_ACCESS_KEY_ID=sua_access_key_id
AWS_SECRET_ACCESS_KEY=sua_secret_access_key

# Porta do servidor Express (padrão: 5000)
PORT=5000
